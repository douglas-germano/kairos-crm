DATABASE_URL=postgresql://kairos:kairos_secret@localhost/kairos_crm
REDIS_URL=redis://localhost:6379/0

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here

# Claude API
ANTHROPIC_API_KEY=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=

# Meta (Instagram)
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=

# URL base do backend (usada no callback OAuth do Instagram)
APP_BASE_URL=http://localhost:5000

# Logs: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
FLASK_ENV=development

# CORS — origens permitidas (separadas por vírgula)
# Em produção, coloque a URL do seu frontend no Railway
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
